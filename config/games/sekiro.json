{
  "game": "sekiro",
  "name": "Sekiro: Shadows Die Twice",
  "platform": "PC",
  "audioEngine": "FMOD",
  "description": "Focus on sword clash and impact effects",
  "audioConfig": {
    "sampleRate": 48000,
    "freqRange": [500, 10000],
    "channels": 2
  },
  "sfxPatterns": [
    {
      "name": "sword_clash",
      "description": "拼刀/拔刀音效",
      "freqRange": [800, 4000],
      "minRMS": 0.15,
      "impactThreshold": 0.4,
      "weight": 0.95
    },
    {
      "name": "sword_hit",
      "description": "剑击中身体的声音",
      "freqRange": [1000, 3500],
      "minRMS": 0.12,
      "impactThreshold": 0.35,
      "weight": 0.85
    },
    {
      "name": "impact",
      "description": "爆炸、冲击波效果",
      "freqRange": [500, 2000],
      "minRMS": 0.1,
      "impactThreshold": 0.3,
      "weight": 0.70
    }
  ],
  "hapticMapping": {
    "mode": "hybrid",
    "minIntensity": 0.3,
    "maxIntensity": 1.0,
    "minDuration": 30,
    "maxDuration": 80,
    "smoothing": 0.3
  },
  "notes": "Sekiro 的音效设计很清晰，拼刀音效特别尖锐，容易识别。建议使用频率 + Onset Detection 组合。"
}
